generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Usuario {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  cpf       String   @unique
  senha     String
  role      String   @default("USER") // 👈 AQUI
  ranking   Int      @default(0)
  createdAt DateTime @default(now())

  avaliacoes  Avaliacao[]
  leituras    Leitura[]
  comentarios Comentario[]
  clubes      ClubeUsuario[]
  anotacaos   Anotacao[]
}

model Livro {
  id        Int      @id @default(autoincrement())
  titulo    String
  autor     String
  descricao String?
  ano       Int?
  genero    String
  capaUrl   String?
  createdAt DateTime @default(now())

  avaliacoes  Avaliacao[]
  leituras    Leitura[]
  comentarios Comentario[]
  anotacaos   Anotacao[]
}

model Avaliacao {
  id         Int      @id @default(autoincrement())
  nota       Int
  comentario String?
  createdAt  DateTime @default(now())

  usuarioId Int
  livroId   Int

  usuario Usuario @relation(fields: [usuarioId], references: [id])
  livro   Livro   @relation(fields: [livroId], references: [id])
}

model Leitura {
  id        Int      @id @default(autoincrement())
  status    String
  progresso Int?
  createdAt DateTime @default(now())

  usuarioId Int
  livroId   Int

  usuario Usuario @relation(fields: [usuarioId], references: [id])
  livro   Livro   @relation(fields: [livroId], references: [id])
}

model Comentario {
  id        Int      @id @default(autoincrement())
  texto     String
  createdAt DateTime @default(now())

  usuarioId Int
  livroId   Int

  usuario Usuario @relation(fields: [usuarioId], references: [id])
  livro   Livro   @relation(fields: [livroId], references: [id])
}

model Anotacao {
  id Int @id @default(autoincrement())

  conteudo String

  createdAt DateTime @default(now())

  usuarioId Int

  livroId Int

  usuario Usuario @relation(fields: [usuarioId], references: [id])

  livro Livro @relation(fields: [livroId], references: [id])
}

model Clube {
  id        Int      @id @default(autoincrement())
  nome      String
  descricao String?
  createdAt DateTime @default(now())

  membros ClubeUsuario[]
}

model ClubeUsuario {
  id Int @id @default(autoincrement())

  usuarioId Int
  clubeId   Int

  usuario Usuario @relation(fields: [usuarioId], references: [id])
  clube   Clube   @relation(fields: [clubeId], references: [id])
}
